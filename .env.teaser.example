# Teaser Generator Environment Configuration Template
# Copy this to .env.teaser and fill in your API keys

# ============================================================================
# OpenAI API (Script Generation)
# Get your key from: https://platform.openai.com/api-keys
# ============================================================================
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
# Model options: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Current: gpt-4o-mini (fast + cost-effective for script generation)

# ============================================================================
# OpenRouter API (Optional primary LLM for script generation)
# Get your key from: https://openrouter.ai/keys
# ============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto

# ============================================================================
# OpenAI TTS API (Text-to-Speech Voice-Over)
# Uses the OpenAI API key you already have
# ============================================================================
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
VOICEOVER_PROVIDER=local
LOCAL_TTS_RATE=0

# Optional fallback if you later get an ElevenLabs key
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1

# ============================================================================
# Segmind API (Text-to-Video Generation)
# Get your key from: https://segmind.com/dashboard
# ============================================================================
SEGMIND_API_KEY=sg_your-segmind-key-here
SEGMIND_API_BASE=https://api.segmind.com/v1
# Model: segmind/text-to-video-ms-1b (Stable Video Diffusion 1B)
# Alternative: Try different T2V APIs like Runway, Pika, etc. with minimal code changes

# ============================================================================
# FFmpeg Configuration
# Specify the path to ffmpeg binary if not in system PATH
# ============================================================================
FFMPEG_BIN=ffmpeg
# On Windows: C:\ffmpeg\bin\ffmpeg.exe
# On macOS: /usr/local/bin/ffmpeg
# On Linux: /usr/bin/ffmpeg

# ============================================================================
# Output Directory
# Where generated teasers and temporary files are stored
# ============================================================================
TEASER_OUTPUT_DIR=./teaser_output
# Ensure this directory has sufficient disk space (videos are large)
# Temp files (~500MB-1GB per teaser) are cleaned up after final assembly

# ============================================================================
# Optional: Cloud Storage (CDN Upload)
# For uploading final teasers to S3, GCS, etc.
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=shortfundly-teaser-cdn
AWS_S3_REGION=us-east-1

# ============================================================================
# Optional: Database Connection
# For storing teaser metadata and tracking generation history
# ============================================================================
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/shortfundly
# Or PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost/shortfundly

# ============================================================================
# Optional: Logging & Debugging
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
ENABLE_DETAILED_LOGGING=true
SAVE_INTERMEDIATE_FILES=false
# Set to true to keep individual clips, shots, and concat files for debugging
